<Window x:Class="AdminDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Network Monitor" Height="400" Width="600"
        Background="#1e1e1e" Foreground="White"
        Closed="Window_Closed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="LIVE NETWORK DASHBOARD" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#00d8ff"/>

        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock Text="Tốc độ Download (KB/s):" FontSize="16" Foreground="LightGray"/>
            <TextBlock Text="{Binding DownloadSpeed, StringFormat={}{0:F2} KB/s}" FontSize="28" FontWeight="Bold" Foreground="#4caf50"/>
            <ProgressBar Value="{Binding DownloadSpeed}" Maximum="5000" Height="15" Margin="0,5,0,0" Foreground="#4caf50" Background="#333"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10">
            <TextBlock Text="Tốc độ Upload (KB/s):" FontSize="16" Foreground="LightGray"/>
            <TextBlock Text="{Binding UploadSpeed, StringFormat={}{0:F2} KB/s}" FontSize="28" FontWeight="Bold" Foreground="#ff9800"/>
            <ProgressBar Value="{Binding UploadSpeed}" Maximum="5000" Height="15" Margin="0,5,0,0" Foreground="#ff9800" Background="#333"/>
        </StackPanel>

        <Border Grid.Row="3" Background="#2d2d30" CornerRadius="8" Padding="15" Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Margin="0,0,40,0">
                    <TextBlock Text="Client Thông thường:" FontSize="14" Foreground="LightGray"/>
                    <TextBlock Text="{Binding StandardClients}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#03a9f4"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Admin Đang theo dõi:" FontSize="14" Foreground="LightGray"/>
                    <TextBlock Text="{Binding AdminClients}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#e91e63"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>