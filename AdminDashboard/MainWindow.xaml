<Window x:Class="AdminDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Advanced Network Monitor" Height="750" Width="1050"
        Background="#FFFFFF" Foreground="#333333"
        Closed="Window_Closed">

    <Grid>
        <TabControl Margin="5" Background="Transparent" BorderThickness="0">

            <TabItem Header="Real-time Monitor" FontSize="14" FontWeight="Bold">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="NETWORK OPERATIONS CENTER (NOC)" FontSize="24" FontWeight="Bold" Foreground="#007acc" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                            <StackPanel>
                                <TextBlock Text="ACTIVE DEVICES" Foreground="#666666" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ActiveClientsCount}" FontSize="28" FontWeight="Bold" Foreground="#88c000" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                            <StackPanel>
                                <TextBlock Text="TOTAL DOWNLOAD" Foreground="#666666" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalDownloadSpeed, StringFormat={}{0:F2} KB/s}" FontSize="24" FontWeight="Bold" Foreground="#0099ff" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                            <StackPanel>
                                <TextBlock Text="TOTAL UPLOAD" Foreground="#666666" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalUploadSpeed, StringFormat={}{0:F2} KB/s}" FontSize="24" FontWeight="Bold" Foreground="#88c000" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                            <StackPanel>
                                <TextBlock Text="ACTIVE ALERTS" Foreground="#666666" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding AlertCount}" FontSize="28" FontWeight="Bold" Foreground="#e74c3c" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="5,0,5,15" Padding="10">
                        <Grid Height="120">
                            <TextBlock Text="Traffic Trend (Xanh dương: Download | Xanh chuối: Upload)" Foreground="#666666" FontSize="12" FontWeight="Bold" VerticalAlignment="Top"/>
                            <Canvas Width="400" Height="100" HorizontalAlignment="Center" Margin="0,15,0,0" ClipToBounds="True">
                                <Line X1="0" Y1="100" X2="400" Y2="100" Stroke="#CCCCCC" StrokeThickness="1"/>
                                <Line X1="0" Y1="0" X2="0" Y2="100" Stroke="#CCCCCC" StrokeThickness="1"/>

                                <Polyline Points="{Binding DownloadPoints}" Stroke="#0099ff" StrokeThickness="2" StrokeLineJoin="Round"/>
                                <Polyline Points="{Binding UploadPoints}" Stroke="#88c000" StrokeThickness="2" StrokeLineJoin="Round"/>
                            </Canvas>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="7*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="5,0,5,0" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Live Traffic (Double-click to Drill-down)" FontWeight="Bold" FontSize="14" Foreground="#666666" Margin="0,0,0,10"/>

                                <DataGrid Grid.Row="1" x:Name="DgClients" ItemsSource="{Binding Clients}" MouseDoubleClick="DgClients_MouseDoubleClick"
                                          AutoGenerateColumns="False" CanUserAddRows="False" Background="Transparent" 
                                          RowBackground="#FFFFFF" AlternatingRowBackground="#F2F5F9" Foreground="#333333" 
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0" BorderThickness="0">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#E9ECEF"/>
                                            <Setter Property="Foreground" Value="#007acc"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Client ID" Binding="{Binding ClientId}" Width="120"/>
                                        <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="120"/>

                                        <DataGridTemplateColumn Header="Download Speed" Width="200">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="5">
                                                        <TextBlock Text="{Binding DownloadSpeedKbps, StringFormat={}{0:F2} KB/s}" Width="80" Foreground="#0099ff" FontWeight="Bold"/>
                                                        <ProgressBar Value="{Binding DownloadSpeedKbps}" Maximum="10000" Width="90" Height="10" Foreground="#0099ff" Background="#E0E0E0" BorderThickness="0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Upload Speed" Width="200">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="5">
                                                        <TextBlock Text="{Binding UploadSpeedKbps, StringFormat={}{0:F2} KB/s}" Width="80" Foreground="#88c000" FontWeight="Bold"/>
                                                        <ProgressBar Value="{Binding UploadSpeedKbps}" Maximum="10000" Width="90" Height="10" Foreground="#88c000" Background="#E0E0E0" BorderThickness="0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="5,0,0,0" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Live Event Feed" FontWeight="Bold" FontSize="14" Foreground="#666666" Margin="0,0,0,10"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding EventLogs}" Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2,0,5" Foreground="#333333"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="System Alerts" FontSize="14" FontWeight="Bold">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="Tải lại cảnh báo" Width="140" Height="35" Click="BtnRefreshAlerts_Click" 
                                Background="#e74c3c" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <TextBlock Text="Danh sách các cảnh báo bất thường từ cơ sở dữ liệu" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#666666" FontStyle="Italic"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="10">
                        <DataGrid x:Name="dgAlerts" ItemsSource="{Binding Alerts}" AutoGenerateColumns="True" IsReadOnly="True" Background="Transparent" 
                                  RowBackground="#FFFFFF" AlternatingRowBackground="#F2F5F9" Foreground="#333333" 
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0" BorderThickness="0">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#E9ECEF"/>
                                    <Setter Property="Foreground" Value="#e74c3c"/>
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Connection Logs" FontSize="14" FontWeight="Bold">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="Tải lại nhật ký" Width="140" Height="35" Click="BtnRefreshLogs_Click" 
                                Background="#007acc" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                        <TextBlock Text="Lịch sử kết nối / ngắt kết nối của các thiết bị" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#666666" FontStyle="Italic"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="10">
                        <DataGrid x:Name="dgLogs" ItemsSource="{Binding Logs}" AutoGenerateColumns="True" IsReadOnly="True" Background="Transparent" 
                                  RowBackground="#FFFFFF" AlternatingRowBackground="#F2F5F9" Foreground="#333333" 
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0" BorderThickness="0">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#E9ECEF"/>
                                    <Setter Property="Foreground" Value="#007acc"/>
                                    <Setter Property="Padding" Value="10,5"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>