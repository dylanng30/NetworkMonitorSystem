<Window x:Class="AdminDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Advanced Network Monitor" Height="450" Width="800"
        Background="#1e1e1e" Foreground="White"
        Closed="Window_Closed">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="LIVE CLIENT MONITORING" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#00d8ff"/>

        <TextBlock Grid.Row="1" x:Name="TxtTotalClients" Text="Tổng số Standard Clients: 0" FontSize="16" FontWeight="Bold" Foreground="#4caf50" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="2" x:Name="DgClients" AutoGenerateColumns="False" CanUserAddRows="False" Background="#2d2d30" Foreground="Black" RowBackground="White" AlternatingRowBackground="#f1f2f6" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Client ID" Binding="{Binding ClientId}" Width="100"/>
                <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="120"/>
                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="80"/>

                <DataGridTemplateColumn Header="Download Speed" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{Binding DownloadSpeedKbps, StringFormat={}{0:F2} KB/s}" Width="80" Foreground="#27ae60" FontWeight="Bold"/>
                                <ProgressBar Value="{Binding DownloadSpeedKbps}" Maximum="10000" Width="100" Height="15" Foreground="#2ecc71"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Upload Speed" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{Binding UploadSpeedKbps, StringFormat={}{0:F2} KB/s}" Width="80" Foreground="#e67e22" FontWeight="Bold"/>
                                <ProgressBar Value="{Binding UploadSpeedKbps}" Maximum="10000" Width="100" Height="15" Foreground="#e67e22"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>