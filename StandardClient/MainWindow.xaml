<Window x:Class="StandardClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Standard Client" Height="300" Width="400"
        Background="#f5f6fa" Closed="Window_Closed">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="CLIENT ỨNG DỤNG" FontSize="20" FontWeight="Bold" Foreground="#2f3640" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="BtnConnect" Content="Kết Nối Server" Width="120" Height="35" Margin="0,0,10,0" Background="#4cd137" Foreground="White" FontWeight="Bold" Click="BtnConnect_Click"/>
            <Button x:Name="BtnDisconnect" Content="Ngắt Kết Nối" Width="120" Height="35" Background="#e84118" Foreground="White" FontWeight="Bold" Click="BtnDisconnect_Click" IsEnabled="False"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#dcdde1" BorderThickness="1" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="Công cụ Test Băng thông:" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnStartTraffic" Content="Bơm Dữ Liệu (Tạo Traffic)" Width="150" Height="30" Margin="0,0,10,0" Background="#00a8ff" Foreground="White" Click="BtnStartTraffic_Click" IsEnabled="False"/>
                    <Button x:Name="BtnStopTraffic" Content="Dừng Bơm" Width="100" Height="30" Background="#7f8fa6" Foreground="White" Click="BtnStopTraffic_Click" IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock x:Name="TxtStatus" Grid.Row="3" Text="Trạng thái: Chưa kết nối" Margin="0,20,0,0" Foreground="#718093" FontStyle="Italic" HorizontalAlignment="Center"/>
    </Grid>
</Window>